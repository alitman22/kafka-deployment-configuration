KafkaServer {
  org.apache.kafka.common.security.plain.PlainLoginModule required
  username="{{ kafka_sasl_interbroker_username }}"
  password="{{ kafka_sasl_interbroker_password }}"
  user_{{ kafka_sasl_admin_username }}="{{ kafka_sasl_admin_password }}"
  user_{{ kafka_sasl_interbroker_username }}="{{ kafka_sasl_interbroker_password }}"
{% for user in kafka_sasl_client_users %}
  user_{{ user.username }}="{{ user.password }}"
{% endfor %}
  ;
};
