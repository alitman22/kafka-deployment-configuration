broker.id={{ kafka_broker_id }}

listeners=INTERNAL://0.0.0.0:{{ kafka_internal_listener_port }}{% if kafka_enable_nat_external_listener %},EXTERNAL://0.0.0.0:{{ kafka_external_listener_port }}{% endif %}
advertised.listeners=INTERNAL://{{ kafka_internal_ip | default(ansible_host) }}:{{ kafka_internal_listener_port }}{% if kafka_enable_nat_external_listener %},EXTERNAL://{{ kafka_external_ip | default(ansible_host) }}:{{ kafka_external_listener_port }}{% endif %}
listener.security.protocol.map=INTERNAL:{{ kafka_internal_protocol }}{% if kafka_enable_nat_external_listener %},EXTERNAL:{{ kafka_external_protocol }}{% endif %}
inter.broker.listener.name=INTERNAL

{% if kafka_security_enabled %}
ssl.keystore.location={{ kafka_ssl_keystore_location }}
ssl.keystore.password={{ kafka_ssl_keystore_password }}
ssl.key.password={{ kafka_ssl_key_password }}
ssl.truststore.location={{ kafka_ssl_truststore_location }}
ssl.truststore.password={{ kafka_ssl_truststore_password }}
ssl.client.auth={{ kafka_ssl_client_auth }}
ssl.endpoint.identification.algorithm=https
{% endif %}

{% if kafka_security_enabled and kafka_security_mode == 'sasl_ssl' %}
sasl.enabled.mechanisms={{ kafka_sasl_mechanism }}
sasl.mechanism.inter.broker.protocol={{ kafka_sasl_inter_broker_mechanism }}
listener.name.internal.{{ kafka_sasl_mechanism | lower }}.sasl.jaas.config=org.apache.kafka.common.security.plain.PlainLoginModule required username="{{ kafka_sasl_interbroker_username }}" password="{{ kafka_sasl_interbroker_password }}";
{% if kafka_enable_nat_external_listener %}
listener.name.external.{{ kafka_sasl_mechanism | lower }}.sasl.jaas.config=org.apache.kafka.common.security.plain.PlainLoginModule required username="{{ kafka_sasl_interbroker_username }}" password="{{ kafka_sasl_interbroker_password }}";
{% endif %}
{% endif %}

{% if kafka_acl_enable | default(false) %}
authorizer.class.name=kafka.security.authorizer.AclAuthorizer
allow.everyone.if.no.acl.found=false
super.users={{ kafka_super_users | join(';') }}
{% endif %}

num.network.threads=3
num.io.threads=8
socket.send.buffer.bytes=102400
socket.receive.buffer.bytes=102400
socket.request.max.bytes=104857600

log.dirs={{ kafka_data_dirs | join(',') }}
num.partitions={{ kafka_num_partitions }}
num.recovery.threads.per.data.dir=1

offsets.topic.replication.factor={{ kafka_offsets_topic_replication_factor }}
transaction.state.log.replication.factor={{ kafka_transaction_state_log_replication_factor }}
transaction.state.log.min.isr={{ kafka_transaction_state_log_min_isr }}
default.replication.factor={{ kafka_replication_factor }}
min.insync.replicas={{ kafka_min_insync_replicas }}
auto.create.topics.enable=false

log.retention.hours={{ kafka_log_retention_hours }}
log.segment.bytes=1073741824
log.retention.check.interval.ms=300000
message.max.bytes={{ kafka_message_max_bytes }}

zookeeper.connect={{ kafka_zookeeper_connect }}
zookeeper.connection.timeout.ms=18000

group.initial.rebalance.delay.ms=0
delete.topic.enable=true
