version: "3.9"
services:
  zk1:
    image: {{ dev_zookeeper_image }}
    hostname: zk1
    environment:
      ZOO_SERVER_ID: 1
      ZOO_SERVERS: server.1=zk1:2888:3888;2181 server.2=zk2:2888:3888;2181 server.3=zk3:2888:3888;2181
      ALLOW_ANONYMOUS_LOGIN: "yes"
    ports: ["22181:2181"]

  zk2:
    image: {{ dev_zookeeper_image }}
    hostname: zk2
    environment:
      ZOO_SERVER_ID: 2
      ZOO_SERVERS: server.1=zk1:2888:3888;2181 server.2=zk2:2888:3888;2181 server.3=zk3:2888:3888;2181
      ALLOW_ANONYMOUS_LOGIN: "yes"

  zk3:
    image: {{ dev_zookeeper_image }}
    hostname: zk3
    environment:
      ZOO_SERVER_ID: 3
      ZOO_SERVERS: server.1=zk1:2888:3888;2181 server.2=zk2:2888:3888;2181 server.3=zk3:2888:3888;2181
      ALLOW_ANONYMOUS_LOGIN: "yes"

  kafka1:
    image: {{ dev_kafka_image }}
    hostname: kafka1
    depends_on: [zk1, zk2, zk3]
    ports:
      - "{{ kafka_external_listener_port_base }}:9094"
      - "17071:7071"
    environment:
      KAFKA_CFG_BROKER_ID: 1
      KAFKA_CFG_ZOOKEEPER_CONNECT: zk1:2181,zk2:2181,zk3:2181
      KAFKA_CFG_LISTENER_SECURITY_PROTOCOL_MAP: INTERNAL:PLAINTEXT,EXTERNAL:PLAINTEXT
      KAFKA_CFG_LISTENERS: INTERNAL://:9092,EXTERNAL://:9094
      KAFKA_CFG_ADVERTISED_LISTENERS: INTERNAL://kafka1:9092,EXTERNAL://localhost:{{ kafka_external_listener_port_base }}
      KAFKA_CFG_INTER_BROKER_LISTENER_NAME: INTERNAL
      KAFKA_HEAP_OPTS: -Xms512m -Xmx512m
      ALLOW_PLAINTEXT_LISTENER: "yes"
      JMX_PORT: 7071

  kafka2:
    image: {{ dev_kafka_image }}
    hostname: kafka2
    depends_on: [zk1, zk2, zk3]
    ports:
      - "{{ kafka_external_listener_port_base + 1 }}:9094"
      - "27071:7071"
    environment:
      KAFKA_CFG_BROKER_ID: 2
      KAFKA_CFG_ZOOKEEPER_CONNECT: zk1:2181,zk2:2181,zk3:2181
      KAFKA_CFG_LISTENER_SECURITY_PROTOCOL_MAP: INTERNAL:PLAINTEXT,EXTERNAL:PLAINTEXT
      KAFKA_CFG_LISTENERS: INTERNAL://:9092,EXTERNAL://:9094
      KAFKA_CFG_ADVERTISED_LISTENERS: INTERNAL://kafka2:9092,EXTERNAL://localhost:{{ kafka_external_listener_port_base + 1 }}
      KAFKA_CFG_INTER_BROKER_LISTENER_NAME: INTERNAL
      KAFKA_HEAP_OPTS: -Xms512m -Xmx512m
      ALLOW_PLAINTEXT_LISTENER: "yes"
      JMX_PORT: 7071

  kafka3:
    image: {{ dev_kafka_image }}
    hostname: kafka3
    depends_on: [zk1, zk2, zk3]
    ports:
      - "{{ kafka_external_listener_port_base + 2 }}:9094"
      - "37071:7071"
    environment:
      KAFKA_CFG_BROKER_ID: 3
      KAFKA_CFG_ZOOKEEPER_CONNECT: zk1:2181,zk2:2181,zk3:2181
      KAFKA_CFG_LISTENER_SECURITY_PROTOCOL_MAP: INTERNAL:PLAINTEXT,EXTERNAL:PLAINTEXT
      KAFKA_CFG_LISTENERS: INTERNAL://:9092,EXTERNAL://:9094
      KAFKA_CFG_ADVERTISED_LISTENERS: INTERNAL://kafka3:9092,EXTERNAL://localhost:{{ kafka_external_listener_port_base + 2 }}
      KAFKA_CFG_INTER_BROKER_LISTENER_NAME: INTERNAL
      KAFKA_HEAP_OPTS: -Xms512m -Xmx512m
      ALLOW_PLAINTEXT_LISTENER: "yes"
      JMX_PORT: 7071

  redpanda-console:
    image: {{ dev_console_image }}
    depends_on: [kafka1, kafka2, kafka3]
    ports:
      - "8080:8080"
    command:
      - /app/console
      - --kafka.brokers
      - kafka1:9092
      - --kafka.brokers
      - kafka2:9092
      - --kafka.brokers
      - kafka3:9092
      - --server.listen-port
      - "8080"

  node-exporter:
    image: {{ dev_node_exporter_image }}
    command:
      - '--path.rootfs=/host'
    network_mode: host
    pid: host
    restart: unless-stopped
    volumes:
      - '/:/host:ro,rslave'

  jmx-exporter-kafka1:
    image: {{ dev_jmx_exporter_image }}
    ports: ["19404:5556"]
    command:
      - "5556"
      - /opt/bitnami/jmx-exporter/config.yml
      - "kafka1:7071"

  jmx-exporter-kafka2:
    image: {{ dev_jmx_exporter_image }}
    ports: ["29404:5556"]
    command:
      - "5556"
      - /opt/bitnami/jmx-exporter/config.yml
      - "kafka2:7071"

  jmx-exporter-kafka3:
    image: {{ dev_jmx_exporter_image }}
    ports: ["39404:5556"]
    command:
      - "5556"
      - /opt/bitnami/jmx-exporter/config.yml
      - "kafka3:7071"
