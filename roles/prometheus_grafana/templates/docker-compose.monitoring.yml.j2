version: "3.9"
services:
  prometheus:
    image: {{ prometheus_grafana_image }}
    ports:
      - "{{ prometheus_grafana_prometheus_port }}:9090"
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
    volumes:
      - './prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro'
      - 'prometheus-data:/prometheus'

  grafana:
    image: {{ prometheus_grafana_grafana_image }}
    depends_on:
      - prometheus
    ports:
      - "{{ prometheus_grafana_grafana_port }}:3000"
    environment:
      GF_SECURITY_ADMIN_USER: {{ prometheus_grafana_grafana_admin_user }}
      GF_SECURITY_ADMIN_PASSWORD: {{ prometheus_grafana_grafana_admin_password }}
    volumes:
      - 'grafana-data:/var/lib/grafana'

volumes:
  prometheus-data:
  grafana-data:
