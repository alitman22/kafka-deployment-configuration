global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ['127.0.0.1:9090']

  - job_name: kafka_node_exporter
    static_configs:
      - targets:
{% for host in groups['kafka'] %}
          - '{{ hostvars[host]['ansible_host'] }}:{{ node_exporter_port }}'
{% endfor %}

  - job_name: kafka_jmx_exporter
    static_configs:
      - targets:
{% for host in groups['kafka'] %}
          - '{{ hostvars[host]['ansible_host'] }}:{{ jmx_exporter_port }}'
{% endfor %}

  - job_name: console_node_exporter
    static_configs:
      - targets:
{% for host in groups['console'] %}
          - '{{ hostvars[host]['ansible_host'] }}:{{ node_exporter_port }}'
{% endfor %}
